# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Supabase Dashboard → Project Settings → API

# Supabase URL (Public)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Supabase Anon Key (Public - RLS ile güvenli)
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# ===========================================
# GROQ API KEY (LLM için - Birincil, Zorunlu)
# ===========================================
# https://console.groq.com adresinden ücretsiz alın
# Model: llama-3.3-70b-versatile (tool calling destekli)
GROQ_API_KEY="gsk_xxxxxxxx"

# ===========================================
# Z.AI (Yedek LLM + Web Arama + Grafik Analizi)
# ===========================================
# Z.AI panelinden alın (local'de .z-ai-config dosyası da kullanılabilir)
ZAI_BASE_URL="https://YOUR-ZAI-INSTANCE/api"
ZAI_API_KEY="your-zai-api-key"

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Supabase Dashboard → Project Settings → API

# Supabase URL (Public)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Supabase Anon Key (Public - RLS ile güvenli)
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# ===========================================
# OPENAI API KEY (LLM için - Zorunlu)
# ===========================================
# https://platform.openai.com/api-keys adresinden alın
# Modeller: gpt-4o (agent), gpt-4o-mini (hızlı işlemler)
OPENAI_API_KEY="sk-proj-xxxxxxxx"

# ===========================================
# YFINANCE MINI-SERVICE (Global Stocks)
# ===========================================
# Run: cd mini-services/yfinance-service && bash start.sh
# Default: http://localhost:8001
YFINANCE_SERVICE_URL="http://localhost:8001"

# ===========================================
# APP URL (for internal API calls)
# ===========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
